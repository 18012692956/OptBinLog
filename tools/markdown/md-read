#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "Usage: tools/markdown/md-read <file.md> [width]"
  exit 1
fi

target="$1"
width="${2:-110}"

if [ ! -f "$target" ]; then
  echo "File not found: $target"
  exit 1
fi

cfg="$(cd "$(dirname "$0")" && pwd)/glow.yml"
glow --config "$cfg" --width "$width" "$target"
